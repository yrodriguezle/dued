# === DuedGusto Production Environment ===
# Copy to .env and fill with real values
# chmod 600 .env

# MySQL
MYSQL_ROOT_PASSWORD=changeme_mysql_root_password
MYSQL_DATABASE=duedgusto

# Backend .NET
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_base64_64
SUPERADMIN_PASSWORD=changeme_superadmin_password

# Domain
DOMAIN=app.duedgusto.com

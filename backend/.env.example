# Environment Variables Configuration
# Copy this file to .env and set your values
# DO NOT commit .env file to version control!
#
# In ambienti non-Development (es. Production) le variabili OBBLIGATORIE sono:
#   CONNECTION_STRING, JWT_SECRET_KEY
# Senza di esse l'applicazione fa fail-fast all'avvio con un errore esplicito.
# In Development esistono fallback locali e nessuna variabile è richiesta.

# --- OBBLIGATORIE in produzione ---

# Database Connection (MySQL 8.0+)
CONNECTION_STRING=server=localhost;database=duedgusto;user=root;password=your-db-password-here

# JWT Secret Key (256-bit recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-secure-random-jwt-key-here

# --- OPZIONALI ---

# Superadmin Password (min 8 characters, use strong password)
# SUPERADMIN_PASSWORD=your-secure-superadmin-password-here

# Seed dati di esempio all'avvio (default: true; impostare "false" per disabilitare)
# SEED_ON_STARTUP=false
